# Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (from Google Cloud Console > Credentials > OAuth 2.0)
# Set authorized redirect URI to: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=fill-it-in
GOOGLE_CLIENT_SECRET=fill-it-in

# PostgreSQL
DATABASE_URL=fill-it-in